{
  "manifest_version": 3,
  "name": "LinkPaddy",
  "version": "1.0",
  "description": "The easiest way to share links with your inner circle",
  "permissions": [
    "identity",
    "storage",
    "identity.email",
    "clipboardRead",
    "tabs",
    "contextMenus",
    "activeTab",
    "alarms"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "Link Sharing Extension"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/images/*", "assets/fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "host_permissions": [
    "https://*.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://*.firebase.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "309540318772-nsj2lle011ifcke7f3l5opp9ql9pr013.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "openid"
    ]  },
  "commands": {
    "share-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Space",
        "mac": "Command+Space"
      },
      "description": "Share current tab with LinkPaddy"
    }  }
}
